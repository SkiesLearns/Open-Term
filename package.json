{
  "name": "openterm",
  "version": "0.2.0",
  "description": "Open-source SSH + FTP/SFTP desktop client",
  "main": "./out/main/index.js",
  "license": "MIT",
  "author": "OpenTerm contributors",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir",
    "dev:ssh-server": "node dev/ssh-server.mjs",
    "dev:ftp-server": "node dev/ftp-server.mjs"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ssh2": "^1.15.1",
    "@types/ssh2-sftp-client": "^9.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "ftp-srv": "^4.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "org.openterm.desktop",
    "productName": "OpenTerm",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["out/**/*", "!node_modules/cpu-features/**", "!node_modules/nan/**"],
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
